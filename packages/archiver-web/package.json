{
  "name": "archiver-web",
  "version": "1.0.0",
  "description": "Universal Archive Extractor & Creator using libarchive.js (WASM). Supports ZIP/7z/RAR4/5/TAR + GZIP/BZIP2/LZMA.",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "extract": "./dist/bin-extract.js",
    "compress": "./dist/bin-compress.js"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "vite build",
    "test": "tsx test.ts"
  },
  "dependencies": {
    "libarchive.js": "^2.0.2"
  },
  "devDependencies": {
    "@types/libarchive.js": "^1.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "license": "MIT"
}
