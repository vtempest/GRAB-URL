{
  "name": "grab-url-docs",
  "description": "FumaDocs Starter - Search, Docs Sidebar, API Docs",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "npx concurrently \"next dev  --turbo \" \"npx wait-on http://localhost:3000 && npx opener http://localhost:3000\"",
    "build": "next build",
    "build:preview": "next build; npx concurrently \"next start \" \"npx wait-on http://localhost:3000 && npx opener http://localhost:3000\"",
    "build:api": "node ./lib/fumadocs/generate-api-docs.ts",
    "check": "fumadocs-mdx && tsc --noEmit",
    "favicon": "npm create favicon public/favicon-512.png public/ -- --overwrite"
  },
  "dependencies": {
    "@fumadocs/mdx-remote": "^1.4.3",
    "@orama/orama": "^3.1.16",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "^16.1.0",
    "fumadocs-mdx": "^14.0.3",
    "fumadocs-openapi": "^10.0.11",
    "fumadocs-typescript": "^4.0.13",
    "fumadocs-ui": "^16.1.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.555.0",
    "next": "^16.1.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shiki": "^3.17.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.8.32",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
