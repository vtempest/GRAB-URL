    "@tailwindcss/postcss": "^4.1.17",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-svg-pan-zoom": "^3.3.9",
    "baseline-browser-mapping": "^2.8.32",
    "open-ready": "^0.1.2",
