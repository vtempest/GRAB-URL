{
  "name": "grab-url-docs",
  "description": "FumaDocs Starter - Search, Docs Sidebar, API Docs",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "scripts": {
    "dev": "rm -rf .next/; open-ready next dev  --turbo",
    "build": "next build",
    "build:preview": "next build; open-ready next start",
    "build:api": "node ./lib/fumadocs/generate-api-docs.ts",
    "check": "fumadocs-mdx && tsc --noEmit",
    "favicon": "npm create favicon public/favicon-512.png public/ -- --overwrite"
  },
  "dependencies": {
    "@fumadocs/mdx-remote": "^1.4.3",
    "@orama/orama": "^3.1.16",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@typescript-eslint/typescript-estree": "^8.56.1",
    "archiver-web": "*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.6.10",
    "fumadocs-mdx": "^14.0.3",
    "fumadocs-openapi": "^10.0.11",
    "fumadocs-typescript": "^4.0.13",
    "fumadocs-ui": "^16.1.0",
    "fuse.js": "^7.1.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.555.0",
