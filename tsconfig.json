{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler", // Recommended for Vite/ESM
    "resolveJsonModule": true,
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "checkJs": false, // Disable JS type checking
    "noImplicitAny": false,
    "declarationDir": "./dist", // Output dir for .d.ts files
    "outDir": "./dist", // Output directory
    "strict": false,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true, // Required for Vite
    "paths": {
      "@grab-url/grab-api": ["./packages/grab-api/index.ts"],
      "@grab-url/log": ["./packages/log-json/log-json.ts"],
      "@grab-url/loading-animations": ["./packages/loading-animations/svg/index.ts"],
      "@grab-url/grab-url-cli": ["./packages/grab-url-cli/index.ts"],
      "@grab-url/archiver-web": ["./packages/archiver-web/src/index.ts"]
    }
  },
  "include": [
    "./packages/**/*.ts",
    "./packages/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}